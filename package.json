{
  "name": "raccoon-browser",
  "version": "0.1.0",
  "description": "🦝 A privacy-focused browser with built-in search engine. Fast. Clever. Yours.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "jest",
    "lint": "eslint src/**/*.{js,ts,tsx}"
  },
  "author": "Cyber & Raccoon",
  "license": "MIT",
  "private": true,
  "keywords": [
    "browser",
    "privacy",
    "search",
    "electron",
    "raccoon"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.1.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.openclaw.raccoon-browser",
    "productName": "Raccoon Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icons/raccoon.icns"
    },
    "win": {
      "icon": "assets/icons/raccoon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "assets/icons/raccoon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network;WebBrowser"
    }
  }
}